{
  "name": "opendesign",
  "version": "0.0.0",
  "scripts": {
    "ng": "ng",
    "start": "ng serve docs",
    "build:lib": "ng build ngx-opendesign && sass --no-source-map --style=expanded projects/ngx-opendesign/styles/opendesign.scss dist/ngx-opendesign/styles/opendesign.css && cp LICENSE dist/ngx-opendesign/LICENSE",
    "build:docs": "ng build docs",
    "test": "ng test ngx-opendesign --watch=false && ng test docs --watch=false",
    "lint": "ng lint",
    "format": "prettier --write \"projects/**/*.{ts,html,scss}\"",
    "format:check": "prettier --check \"projects/**/*.{ts,html,scss}\"",
    "prepare": "husky"
  },
  "private": true,
  "packageManager": "npm@11.16.0",
  "dependencies": {
    "@angular/cdk": "^22.0.5",
    "@angular/common": "^22.0.0",
    "@angular/compiler": "^22.0.0",
    "@angular/core": "^22.0.0",
    "@angular/forms": "^22.0.0",
    "@angular/platform-browser": "^22.0.0",
    "@angular/router": "^22.0.0",
    "highlight.js": "^11.11.1",
    "rxjs": "~7.8.0",
    "tslib": "^2.3.0"
  },
  "devDependencies": {
    "@angular/build": "^22.0.7",
    "@angular/cli": "^22.0.7",
    "@angular/compiler-cli": "^22.0.0",
    "@eslint/js": "^10.0.1",
    "angular-eslint": "22.1.0",
    "eslint": "^10.6.0",
    "husky": "^9.1.7",
    "jsdom": "^28.0.0",
    "lint-staged": "^17.0.8",
    "ng-packagr": "^22.0.0",
    "prettier": "^3.9.5",
    "sass": "^1.101.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "8.62.1",
    "vitest": "^4.0.8"
  },
  "lint-staged": {
    "projects/**/*.ts": ["eslint --fix", "prettier --write"],
    "projects/**/*.{html,scss}": "prettier --write"
  }
}
